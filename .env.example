# === HU AI Platform Configuration ===

# OpenAI (required for LLM and embeddings)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Azure OpenAI (optional — overrides OpenAI when set)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Search (optional — uses FAISS locally by default)
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_KEY=your-search-key
# AZURE_SEARCH_INDEX=hu-knowledge

# Vector store: "faiss" (local) or "azure"
VECTOR_STORE_TYPE=faiss
FAISS_INDEX_PATH=data/faiss_index

# Session store: "sqlite" (local) or "cosmos"
SESSION_STORE_TYPE=sqlite
SQLITE_PATH=data/sessions.db

# Observability
OTEL_ENABLED=false
# OTEL_ENDPOINT=http://localhost:4317

# Application
DEBUG=false
LOG_LEVEL=INFO
